# ─── Model selection ──────────────────────────────────────────────────────
# Override the model used by all agents. Defaults to claude-sonnet-4-6.
# Anthropic:   claude-sonnet-4-6 | claude-opus-4-7 | claude-haiku-4-5-20251001
# OpenAI:      gpt-4o-mini | gpt-4o | gpt-4.1 | o3-mini
# Gemini:      gemini/gemini-2.5-flash | gemini/gemini-2.5-pro
# Ollama:      ollama/llama3.2 | ollama/qwen2.5:14b | ollama_chat/...
# OpenRouter:  openrouter/anthropic/claude-3.5-sonnet
# AGENT_MODEL=gemini/gemini-2.5-flash

# ─── Provider credentials (only set the one you need) ─────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_VERSION=2024-08-01-preview

# ─── Ollama (local) ───────────────────────────────────────────────────────
# OLLAMA_API_BASE=http://localhost:11434
